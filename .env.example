# =============================================================================
# Ecommerce Automation Framework — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# API tests default to the Platzi Fake Store API (https://api.escuelajs.co/api/v1),
# a public ecommerce API playground.  Override API_BASE_URL to target a
# different API.
# =============================================================================

# ── API Configuration ─────────────────────────────────────────────────────────
API_BASE_URL=https://api.escuelajs.co/api/v1

# Preferred authentication method (one of token / api-key / credentials)
# If TOKEN is set it takes precedence, then API_KEY, then USERNAME+PASSWORD.
API_TOKEN=
API_KEY=

# Credentials used to obtain a bearer token at login time
API_USERNAME=john@mail.com
API_PASSWORD=changeme

# Request tuning
API_DEFAULT_TIMEOUT=30
API_MAX_RETRIES=3
API_RETRY_BACKOFF_FACTOR=0.5
API_RETRY_STATUS_CODES=429,500,502,503,504
API_MAX_RESPONSE_TIME=2.0
API_DEFAULT_PAGE_SIZE=10
API_DEFAULT_PAGE=1

# ── Selenium / UI Configuration ───────────────────────────────────────────────
BASE_URL=https://www.saucedemo.com/
