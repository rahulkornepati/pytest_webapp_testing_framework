{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order",
  "description": "Schema for an order resource",
  "type": "object",
  "required": ["id", "userId", "date", "products", "total"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 1
    },
    "userId": {
      "type": "integer",
      "minimum": 1
    },
    "date": {
      "type": "string"
    },
    "products": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "productId": {
            "type": "integer",
            "minimum": 1
          },
          "quantity": {
            "type": "integer",
            "minimum": 1
          },
          "price": {
            "type": "number",
            "minimum": 0
          }
        },
        "required": ["productId", "quantity"],
        "additionalProperties": true
      },
      "minItems": 0
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "status": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
